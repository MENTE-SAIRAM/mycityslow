        {
            "name": "2. Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"name\": \"iOS Dev\", \"email\": \"ios@test.com\", \"password\": \"Password@123\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/register",
                            "host": [

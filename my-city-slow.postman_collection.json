                {
                    "name": "Submit a Spot",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"A Secret Tree\",\n  \"description\": \"Quiet space to read.\",\n  \"city\": \"Pune\",\n  \"categories\": [\"parks\"],\n  \"vibe\": \"very-calm\",\n  \"bestTime\": \"morning\",\n  \"crowdLevel\": \"very-low\",\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [73.8567, 18.5204]\n  }\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/spots/submit",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "spots",
                                "submit"
                            ]
                        }
                    }
                },
                {
                    "name": "Submit a Review for a Spot",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"rating\": 5,\n  \"text\": \"Very peaceful, no crowds at all.\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/spots/:spotId/reviews",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "spots",
                                ":spotId",
                                "reviews"
                            ],
                            "variable": [
                                {
                                    "key": "spotId",
                                    "value": "SPOT_ID_HERE"
                                }
                            ]
                        }
                    }
                }
